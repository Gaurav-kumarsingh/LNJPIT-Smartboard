# ═══════════════════════════════════════════════════════════════
# SMARTBOARD — ENVIRONMENT TEMPLATE
# 1. cp .env.example .env
# 2. Fill in every value
# 3. NEVER commit .env to git (already in .gitignore)
# On Render: add each key under Environment Variables
# ═══════════════════════════════════════════════════════════════

PORT=3000

# ─── MongoDB Atlas ───────────────────────────────────────────────
# ONLY stores user accounts (username + bcrypt-hashed password).
# Files (PDF, images, video) are stored on disk — NOT in MongoDB.
# Get the URI from: Atlas → Cluster → Connect → Drivers (Node.js)
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/smartboard?retryWrites=true&w=majority

# ─── JWT Secrets ─────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGE_ME_strong_random_user_token_key
ADMIN_JWT_SECRET=CHANGE_ME_strong_random_admin_token_key

# ─── Admin Credentials ───────────────────────────────────────────
# Loaded on the backend ONLY via process.env.
# bcrypt-hashed before storage — never exposed in source or API.
ADMIN_USERNAME=YourAdminUsername
ADMIN_PASSWORD=YourStrongAdminPassword
