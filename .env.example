# ═══════════════════════════════════════════════════════════════
# SMARTBOARD — ENVIRONMENT CONFIGURATION TEMPLATE
# DO NOT COMMIT THIS FILE WITH REAL VALUES TO GIT
# Copy this file to .env and fill in your actual values
# For production on Render: use the Environment UI instead
# ═══════════════════════════════════════════════════════════════

# Application Environment
NODE_ENV=development
PORT=3000

# ─── MongoDB Atlas ───────────────────────────────────────────────
# Get your connection string from MongoDB Atlas:
# 1. Go to Clusters → Connect → Drivers
# 2. Choose Node.js and copy the connection string
# 3. Replace <username> and <password> with your Atlas credentials
# Format: mongodb+srv://username:password@cluster.mongodb.net/smartboard?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://your_username:your_password@your-cluster.mongodb.net/smartboard?retryWrites=true&w=majority

# ─── JWT Secrets ─────────────────────────────────────────────────
# GENERATE RANDOM 32+ CHARACTER STRINGS:
# On Linux/Mac: openssl rand -base64 32
# On Windows PowerShell: [Convert]::ToBase64String([System.Text.Encoding]::UTF8.GetBytes((1..32 | % {[char][int](Get-Random -Min 33 -Max 127))} -join '')))
JWT_SECRET=your_random_32_character_secret_here
ADMIN_JWT_SECRET=your_random_32_character_admin_secret_here

# ─── Admin Credentials ──────────────────────────────────────────
# Change these to your desired admin credentials
# Password must be at least 12 characters in production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password_here

# ─── Frontend URL ──────────────────────────────────────────────
# For production on Render, set this to your actual domain
# Example: https://smartboard.onrender.com
FRONTEND_URL=http://localhost:3000

# ─── Default User (Optional) ────────────────────────────────────
# These will be created on server startup if they don't exist
# Leave blank to skip
DEFAULT_USER_USERNAME=student1
DEFAULT_USER_PASSWORD=student_password_123
